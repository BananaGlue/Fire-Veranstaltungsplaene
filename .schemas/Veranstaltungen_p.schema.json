{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fireapp.io/Veranstaltung_p.schema.json",
  "title": "Georeferenzierte Veranstaltungspläne Linien",
  "description": "Im folgenden werden die Ausprägungen der einzelnen Punkttypen und deren gedachter Anwendungszweck definiert.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "FeatureCollection"
      ]
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "Feature"
            ]
          },
          "geometry": {
            "oneOf": [
              {
                "$ref": "GeoJSON.schema.json#/$defs/Point"
              },
              {
                "$ref": "GeoJSON.schema.json#/$defs/MultiPoint"
              }
            ]
          },
          "properties": {
            "type": "object",
            "properties": {
              "Typ": {
                "description": "Definiert den Typ des Features, notwendig für die Darstellungskonfiguration (Style).",
                "type": "string",
                "oneOf": [
                  { 
                    "enum": [
                      "Hinweis",
                      "Bereitstellungsraum",
                      "Bereitstellungszone",
                      "Einsatzleitung",
                      "Befehlsstelle",
                      "Drohnengruppe",
                      "Behandlungsplatz"
                    ] 
                  },
                  { 
                    "pattern": "^Punkt Rot ([1-9]|[1-4][0-9]|50|[A-Z])$" 
                  },
                  { 
                    "pattern": "^Punkt Gelb ([1-9]|[1-4][0-9]|50|[A-Z])$" 
                  },
                  { 
                    "pattern": "^Punkt Grün ([1-9]|[1-4][0-9]|50|[A-Z])$" 
                  },
                  { 
                    "pattern": "^Punkt Blau ([1-9]|[1-4][0-9]|50|[A-Z])$" 
                  },
                  { 
                    "pattern": "^Punkt Lila ([1-9]|[1-4][0-9]|50|[A-Z])$" 
                  }
                ]
              },
              "Titel": {
                "description": "Optionaler Titel, der in der Karte unter eines Punkt, entlang einer Linie oder innerhalb eines Polygones dargestellt wird.",
                "type": "string"
              },
              "Info": {
                "description": "Optionale Hinweise, die in einer Detailansicht zum Kartenelement dargestellt werden.",
                "type": "string"
              },
              "Gefahren": {
                "description": "Optionale Gefahrenhinweise, die in einer Detailansicht zum Kartenelement dargestellt werden.",
                "type": "string"
              }
            },
            "required": [
              "Typ"
            ]
          }
        },
        "required": [
          "type",
          "geometry",
          "properties"
        ]
      }
    }
  },
  "required": [
    "type",
    "features"
  ]  
}